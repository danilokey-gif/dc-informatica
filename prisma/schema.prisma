generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  passwordHash   String
  role           String         @default("TECNICO") // ADMIN | TECNICO
  assignedOrders ServiceOrder[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Customer {
  id            String               @id @default(cuid())
  name          String
  document      String?
  phone         String?
  address       String?
  email         String?
  serviceOrders ServiceOrder[]
  sales         Sale[]
  transactions  FinanceTransaction[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model ServiceOrder {
  id              String               @id @default(cuid())
  customer        Customer             @relation(fields: [customerId], references: [id])
  customerId      String
  device          String
  issue           String
  technicalReport String?
  price           Float?
  status          String               @default("BUDGET")
  technician      User?                @relation(fields: [technicianId], references: [id])
  technicianId    String?
  nfseEmissoes    NfseEmissao[]
  transactions    FinanceTransaction[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Product {
  id            String     @id @default(cuid())
  name          String
  sku           String?    @unique
  description   String?
  category      String?
  costPrice     Float      @default(0)
  salePrice     Float      @default(0)
  stockQty      Int        @default(0)
  minStockAlert Int        @default(0)
  saleItems     SaleItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Sale {
  id            String              @id @default(cuid())
  customer      Customer?           @relation(fields: [customerId], references: [id])
  customerId    String?
  items         SaleItem[]
  total         Float
  paymentMethod String
  invoiceNumber String?
  invoiceType   String?
  status        String              @default("COMPLETED")
  transaction   FinanceTransaction?
  createdAt     DateTime            @default(now())
}

model SaleItem {
  id        String  @id @default(cuid())
  sale      Sale    @relation(fields: [saleId], references: [id])
  saleId    String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  unitPrice Float
}

model CompanySettings {
  id        String   @id @default("main")
  name      String   @default("Dc Informática")
  document  String?
  phone     String?
  email     String?
  address   String?
  logo      String?
  pixKey    String?
  pixCity   String?
  updatedAt DateTime @updatedAt
}

model NfseConfig {
  id               String   @id @default("main")
  ambiente         String   @default("homologacao")
  regimeTributario String   @default("MEI") // MEI | SIMPLES | NORMAL
  codigoMunicipio  String?
  codigoServico    String?
  cnae             String?
  aliquotaIss      Float?
  certificado      String?
  certificadoSenha String?
  certificadoNome  String?
  serieDps         String   @default("1")
  proximoNumeroDps Int      @default(1)
  updatedAt        DateTime @updatedAt
}

model NfseEmissao {
  id             String       @id @default(cuid())
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String
  ambiente       String
  numeroDps      Int
  serieDps       String
  status         String       @default("PROCESSANDO")
  chaveAcesso    String?
  xmlDps         String?
  xmlNfse        String?
  motivoErro     String?
  createdAt      DateTime     @default(now())
}

model Supplier {
  id           String               @id @default(cuid())
  name         String
  document     String?
  phone        String?
  email        String?
  address      String?
  transactions FinanceTransaction[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model FinanceCategory {
  id           String               @id @default(cuid())
  name         String
  type         String // RECEITA | DESPESA
  transactions FinanceTransaction[]
  createdAt    DateTime             @default(now())
}

model FinanceTransaction {
  id             String           @id @default(cuid())
  type           String // RECEITA | DESPESA
  description    String
  amount         Float
  dueDate        DateTime
  paidDate       DateTime?
  status         String           @default("PENDENTE") // PENDENTE | PAGO | CANCELADO
  paymentMethod  String?
  notes          String?
  category       FinanceCategory? @relation(fields: [categoryId], references: [id])
  categoryId     String?
  supplier       Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId     String?
  customer       Customer?        @relation(fields: [customerId], references: [id])
  customerId     String?
  sale           Sale?            @relation(fields: [saleId], references: [id])
  saleId         String?          @unique
  serviceOrder   ServiceOrder?    @relation(fields: [serviceOrderId], references: [id])
  serviceOrderId String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}
